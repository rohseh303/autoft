# --- backend selection (the BFF picks the first one that's set) -------------
#
# 1. LOCAL backend (the demo path) — the FastAPI server in ../local_server.
#    Streams BOTH research and training over SSE. Start it with:
#       ./local_server/run.sh          # serves on :8000
#    then point the BFF at it:
AUTOFT_BACKEND=http://localhost:8000
#
# 2. MODAL backend — the deployed cloud app (training streams; research blocks):
#    MODAL_API_BASE=https://<you>--autoft-web.modal.run
#
# 3. Neither set -> MOCK mode: everything simulated inside the BFF, zero infra.

# Port the Elysia BFF listens on (Vite dev proxy targets this).
PORT=8787
