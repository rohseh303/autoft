# Leave MODAL_API_BASE unset to run in MOCK mode — full UI, simulated agent +
# training stream, zero GPUs / secrets / deploy required. `bun run dev` and go.
#
# Set it to your deployed Modal web URL to drive the real backend:
#   MODAL_API_BASE=https://<you>--autoft-web.modal.run
MODAL_API_BASE=

# Port the Elysia BFF listens on (Vite dev proxy targets this).
PORT=8787
